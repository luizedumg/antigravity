generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Contract {
  id              String   @id @default(uuid())
  patientName     String
  patientCpf      String
  patientWhatsApp String?  // Número completo internacional (ex: 5531999887766)
  patientAddress  String
  surgeryType     String
  status          String   @default("PENDENTE") // PENDENTE, ENVIADO, VISUALIZADO, ASSINATURA_PARCIAL, ASSINADO, DRIVE_OK, RECUSADO
  linkId          String?  @unique // unique link id to send via whatsapp
  zapsignToken      String?  // ZapSign document token id
  patientSignUrl    String?  // URL ZapSign para assinatura do paciente
  responsavelSignUrl String? // URL ZapSign para assinatura do responsável legal
  nomeResponsavel   String?  // Nome do responsável legal (extraído do formulário)
  signUrlsCreatedAt DateTime? // Quando as URLs foram geradas (expiram em 30 dias)
  formData          String?  // JSON format for other dynamic inputs
  googleDriveFileId String? // ID do arquivo no Google Drive após upload
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model SurgeryTemplate {
  id              String   @id @default(uuid())
  name            String   @unique // ex: Rinoplastia
  questionsJson   String   // Form schema
  baseFilename    String?  // Document docx name associated with this template
}

model ApiKey {
  id        String   @id @default(uuid())
  provider  String   @unique  // gemini, openai, claude
  key       String             // chave da API
  createdAt DateTime @default(now())
}
