        "jsonBody": "={{ JSON.stringify({ number: $json.sender, text: '⚠️ Não há orçamento pendente.\\nEnvie uma nova solicitação com a palavra *orçamento*.' }) }}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
