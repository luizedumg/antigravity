          "parameters": [
            { "name": "apikey", "value": "B5FC5AA9C77E-40CC-8917-F6C4EAC23147" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ number: $('Extrair Dados').first().json.sender, text: '✅ *Orçamento Gerado!*\\n\\n💰 Total: R$ ' + ($json.totalPrice || 0).toLocaleString('pt-BR') + '\\n👤 ' + ($json.patientName || '') + '\\n🏥 ' + ($json.surgeryType || '') + '\\n\\n🔗 *Link:*\\n' + ($json.magicLink || '') + '\\n\\n_Envie este link ao paciente._' }) }}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2080, 360],
      "id": "a14",
